# Simple HTTP Server in Fyra IR using capabilities.

extern net.socket(l, l, l) : l
extern net.bind(l, l, l)
extern net.listen(l, l)
extern net.accept(l, l, l) : l
extern io.write(l, l, l) : l
extern io.close(l)

# sockaddr_in structure (16 bytes)
# sin_family: 2 (AF_INET) - 2 bytes
# sin_port: 8080 (0x1F90, in network byte order: 0x901F) - 2 bytes
# sin_addr: 0.0.0.0 (0) - 4 bytes
# sin_zero: 8 bytes of padding
data $addr = { h 2, h 36895, w 0, l 0 }

data $msg = { b "HTTP/1.1 200 OK\r\nContent-Length: 13\r\n\r\nHello, World!", b 0 }

export function $main() : w {
@m_start
    # socket(AF_INET=2, SOCK_STREAM=1, 0)
    %fd = extern net.socket(2, 1, 0) : l

    # bind(fd, $addr, 16)
    extern net.bind(%fd, $addr, 16)

    # listen(fd, 5)
    extern net.listen(%fd, 5)

@m_loop
    # accept(fd, 0, 0)
    %client = extern net.accept(%fd, 0, 0) : l

    # write(client, $msg, 53)
    %w = extern io.write(%client, $msg, 53) : l

    # close(client)
    extern io.close(%client)

    jmp @m_loop

    ret 0 : w
}
