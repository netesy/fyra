# Simple HTTP Server in Fyra IR (Linux x86_64)

# Syscall numbers (Linux x64)
# socket: 41
# bind: 49
# listen: 50
# accept: 43
# write: 1
# close: 3
# exit: 60

# sockaddr_in structure (16 bytes)
# sin_family: 2 (AF_INET) - 2 bytes
# sin_port: 8080 (0x1F90, in network byte order: 0x901F) - 2 bytes
# sin_addr: 0.0.0.0 (0) - 4 bytes
# sin_zero: 8 bytes of padding
data $addr = { h 2, h 36895, w 0, l 0 }

data $msg = { b "HTTP/1.1 200 OK\r\nContent-Length: 13\r\n\r\nHello, World!", b 0 }

export function $main() : w {
@m_start
    # socket(AF_INET=2, SOCK_STREAM=1, 0)
    %fd = syscall(l 41, l 2, l 1, l 0) : l

    # bind(fd, $addr, 16)
    %b = syscall(l 49, l %fd, l $addr, l 16) : l

    # listen(fd, 5)
    %l = syscall(l 50, l %fd, l 5, l 0) : l

@m_loop
    # accept(fd, 0, 0)
    %client = syscall(l 43, l %fd, l 0, l 0) : l

    # write(client, $msg, 53)
    %w = syscall(l 1, l %client, l $msg, l 53) : l

    # close(client)
    %c = syscall(l 3, l %client, l 0, l 0) : l

    jmp @m_loop

    ret 0 : w
}
